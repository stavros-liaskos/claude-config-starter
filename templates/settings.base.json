{
  "permissions": {
    "allow": [
      "Bash(git diff *)",
      "Bash(git status *)",
      "Bash(git grep *)",
      "Bash(git fetch *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git push *)",
      "Bash(git --no-pager diff *)",

      "Bash(ls *)",
      "Bash(echo *)",

      "Bash(npx tsc *)",
      "Bash(npx vitest *)",

      "mcp__newrelic__execute_nrql_query",
      "mcp__newrelic__list_available_new_relic_accounts",
      "WebFetch(domain:onenr.io)"
    ],
    "deny": [
      "Read(**/.env*)",
      "Edit(**/.env*)",

      "Read(**/*.pem)",
      "Edit(**/*.pem)",
      "Read(**/*.key)",
      "Edit(**/*.key)",
      "Read(**/*.p12)",
      "Edit(**/*.p12)",
      "Read(**/*.pfx)",
      "Edit(**/*.pfx)",
      "Read(**/id_rsa)",
      "Edit(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Edit(**/id_ed25519)",

      "Bash(rm -rf *)",
      "Bash(rm -fr *)",

      "Bash(git reset --hard *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git push --force-with-lease*)",
      "Bash(git push --force-if-includes*)",
      "Bash(git clean -f*)",

      "Bash(sudo)"
    ]
  }
}
